SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN

# true のときだけメール通知フォールバックを有効化
ENABLE_EMAIL_FALLBACK=false
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=notify@example.com
RESEND_TO_EMAIL=your-smartphone-mail@example.com

# true にすると在庫変化がなくてもテスト通知を送信
FORCE_TEST_NOTIFICATION=false

# テスト用に監視対象を差し替える場合に使用（JSON配列）
# PRODUCTS_JSON=[{"name":"mock-variant","url":"http://127.0.0.1:4173/variant-checking.html","watchMode":"variant_size","targetSize":"13"}]

# テスト用に連続判定閾値を上書き（通常は2）
# CONSECUTIVE_NON_CHECKING_THRESHOLD=1
