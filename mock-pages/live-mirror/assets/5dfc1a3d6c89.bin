  $(window).on('load', function(){

		$(window).on('hashchange', function(){
			if ( location.hash !== '' ) {
				$('html,body').animate({scrollTop: $(location.hash).offset().top - 50}, 350);
			}
		});

		if ( location.hash !== '' ) {
			$('html,body').animate({scrollTop: $(location.hash).offset().top - 50}, 0);
		}

  });

</script>


