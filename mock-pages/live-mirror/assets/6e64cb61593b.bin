    #shopify-section-footer-ringo .footer a:hover {
      
        opacity: 0.8;
      
    }
  
    #shopify-section-footer-ringo .footer-copyright {
      
      padding: 0px 0;
      padding-bottom: 12px;
    }
  </style>

<style data-shopify>
  .footer {
    flex-direction: row;
    font-size: 11px;
  }
  .footer * {
    margin:0;
    padding: 0;
  }
  .footer .footer-item {
    margin: 0;
    padding-bottom: 12px;
  }
  .pc_br {
    display: block;
  }
  @media screen and (max-width:768px){
    .pc_br {
      display: none;
    }
    .footer-menus span {
      display: inline;
      padding: 0 .5em;
    }
    .footer-links {
      margin-left: auto;
    }
  }
   
</style>

  

</div>
